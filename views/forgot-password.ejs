<%- include('partials/head') %>

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
  <div class="row w-100 justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4">
          <h3 class="card-title text-center mb-4 fw-bold text-danger">Reset Password</h3>
          <p class="text-center text-muted mb-4">Enter your email and new password</p>

          <form method="POST" action="/api/users/reset-password" novalidate>
            <div class="mb-3">
              <label for="email" class="form-label fw-semibold">Email address</label>
              <input 
                type="email" 
                class="form-control form-control-lg" 
                id="email" 
                name="email" 
                placeholder="you@example.com" 
                required
              >
            </div>

            <div class="mb-3">
              <label for="newPassword" class="form-label fw-semibold">New Password</label>
              <input 
                type="password" 
                class="form-control form-control-lg" 
                id="newPassword" 
                name="newPassword" 
                placeholder="Enter new password" 
                required
              >
            </div>

            <button type="submit" class="btn btn-danger btn-lg w-100">Update Password</button>
          </form>

          <hr class="my-4">

          <p class="text-center mb-0">
            <a href="/login" class="text-decoration-none fw-semibold">Back to Login</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>