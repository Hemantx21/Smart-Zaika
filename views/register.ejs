<%- include('partials/head') %>

<div class="container" style="min-height:70vh;">
  <div class="row justify-content-center align-items-center">
    <div class="col-sm-10 col-md-8 col-lg-6">
      <div class="card shadow-sm mt-5">
        <div class="card-body p-4">
          <div class="text-center mb-4">
            <img src="/images/logo.png" alt="Smart Zaika" height="48" onerror="this.onerror=null;this.src='https://via.placeholder.com/48x48?text=SZ';" />
            <h3 class="card-title mt-2 text-brand">Create your account</h3>
            <p class="text-muted small mb-0">Join Smart Zaika to save recipes and generate personalised suggestions.</p>
          </div>

          <form id="registerForm" method="POST" action="/api/users/register" novalidate>
            <div class="mb-3">
              <label for="name" class="form-label small">Full name</label>
              <input id="name" name="name" type="text" class="form-control" placeholder="Your name" required>
              <div class="invalid-feedback">Please enter your name.</div>
            </div>

            <div class="mb-3">
              <label for="email" class="form-label small">Email</label>
              <input id="email" name="email" type="email" class="form-control" placeholder="you@example.com" required>
              <div class="invalid-feedback">Please enter a valid email address.</div>
            </div>

            <div class="mb-3">
              <label for="dob" class="form-label small">Date of birth (optional)</label>
              <input id="dob" name="dob" type="date" class="form-control">
            </div>

            <div class="mb-3 position-relative">
              <label for="password" class="form-label small">Password</label>
              <div class="input-group">
                <input id="password" name="password" type="password" class="form-control" placeholder="Choose a password" minlength="6" required>
                <button class="btn btn-outline-secondary" type="button" id="togglePwd" aria-label="Show password">
                  <i class="fa fa-eye"></i>
                </button>
              </div>
              <div class="form-text small text-muted">Minimum 6 characters.</div>
              <div class="invalid-feedback">Please provide a password (min 6 characters).</div>
            </div>

            <div class="mb-3">
              <label for="passwordConfirm" class="form-label small">Confirm password</label>
              <input id="passwordConfirm" name="passwordConfirm" type="password" class="form-control" placeholder="Confirm password" required>
              <div class="invalid-feedback">Passwords do not match.</div>
            </div>

            <div class="d-grid mb-3">
              <button id="submitBtn" type="submit" class="btn btn-primary btn-lg">Create account</button>
            </div>

            <div class="text-center small text-muted">
              By creating an account you agree to our <a href="/privacy" class="text-decoration-none">Privacy Policy</a>.
            </div>

            <hr class="my-3">

            <div class="text-center small">
              Already have an account? <a href="/login" class="text-decoration-none">Sign in</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // client-side validation + show password
  (function(){
    const form = document.getElementById('registerForm');
    const pwd = document.getElementById('password');
    const pwdConfirm = document.getElementById('passwordConfirm');
    const toggle = document.getElementById('togglePwd');

    toggle?.addEventListener('click', () => {
      const icon = toggle.querySelector('i');
      if (pwd.type === 'password') {
        pwd.type = pwdConfirm.type = 'text';
        icon.classList.remove('fa-eye'); icon.classList.add('fa-eye-slash');
      } else {
        pwd.type = pwdConfirm.type = 'password';
        icon.classList.remove('fa-eye-slash'); icon.classList.add('fa-eye');
      }
    });

    form?.addEventListener('submit', (e) => {
      // reset bootstrap validation states
      form.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));

      let valid = true;
      if (!form.name.value.trim()) {
        form.name.classList.add('is-invalid'); valid = false;
      }
      if (!form.email.value.trim() || !/\S+@\S+\.\S+/.test(form.email.value)) {
        form.email.classList.add('is-invalid'); valid = false;
      }
      if (!form.password.value || form.password.value.length < 6) {
        form.password.classList.add('is-invalid'); valid = false;
      }
      if (form.password.value !== form.passwordConfirm.value) {
        form.passwordConfirm.classList.add('is-invalid'); valid = false;
      }

      if (!valid) {
        e.preventDefault();
        e.stopPropagation();
        return false;
      }

      // allow form to submit (server will handle DB save and redirect)
      return true;
    });
  })();
</script>

<%- include('partials/footer') %>
