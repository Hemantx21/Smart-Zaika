<%- include('partials/head') %>

<div class="container py-5">
  <h1 class="text-center mb-5 fw-bold text-danger"><%= title %></h1> <!-- 🔴 Title in red -->

  <div class="row g-4">
    <% if (recipes && recipes.length) { %>
      <% recipes.forEach(function(recipe) { %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm border-0 rounded-3 recipe-card">
            <img 
              src="<%= recipe.image || '/images/placeholder.jpg' %>" 
              class="card-img-top rounded-top" 
              alt="<%= recipe.title %>"
              style="object-fit: cover; height: 220px;"
            >
            <div class="card-body d-flex flex-column">
              <h5 class="card-title fw-semibold text-dark"><%= recipe.title %></h5>
              <p class="card-text text-muted small flex-grow-1">
                <%= recipe.description || 'No description available.' %>
              </p>
              <!-- 🔴 Red button -->
              <a href="/recipes/<%= recipe._id %>" class="btn btn-danger mt-2 w-100">
                View Recipe
              </a>
            </div>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="col-12">
        <div class="alert alert-info text-center shadow-sm">
          <i class="bi bi-info-circle me-2"></i> No recipes found. Try adding some!
        </div>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>

<style>
  .recipe-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .recipe-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
  }
</style>