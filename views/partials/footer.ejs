<!-- footer -->
<footer class="site-footer">
  <!-- Newsletter / CTA (gradient) -->
  <section class="footer-cta py-5">
    <div class="container-fluid px-4">
      <div class="container text-center">
        <h3 class="fw-bold mb-2">Stay Updated with Smart-Zaika</h3>
        <p class="text-muted mb-3">
          Get the latest recipes, tips and AI-powered culinary insights delivered straight to your inbox.
        </p>

        <form
          id="newsletterForm"
          class="row g-2 justify-content-center align-items-center"
          action="#"
          method="POST"
          onsubmit="event.preventDefault(); alert('Subscribed — demo');"
        >
          <div class="col-sm-4">
            <input
              type="text"
              class="form-control form-control-lg"
              placeholder="Your Name"
              required
            />
          </div>
          <div class="col-sm-4">
            <input
              type="email"
              class="form-control form-control-lg"
              placeholder="Your Email Address"
              required
            />
          </div>
          <div class="col-sm-2 d-grid">
            <button class="btn btn-cta btn-lg" type="submit">
              Subscribe to Newsletter
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Feature highlights (cards) -->
  <section class="footer-highlights py-4">
    <div class="container">
      <div class="row text-center g-3">
        <div class="col-md-4">
          <div class="highlight-card p-4 rounded shadow-sm">
            <i class="fas fa-box-open fa-2x text-orange mb-2"></i>
            <h6 class="fw-bold mb-1">Weekly Recipes</h6>
            <p class="small text-muted mb-0">
              Get 5+ curated recipes delivered every week.
            </p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="highlight-card p-4 rounded shadow-sm">
            <i class="fas fa-utensils fa-2x text-orange mb-2"></i>
            <h6 class="fw-bold mb-1">Cooking Tips</h6>
            <p class="small text-muted mb-0">
              Expert tips and tricks from professional cooks.
            </p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="highlight-card p-4 rounded shadow-sm">
            <i class="fas fa-gift fa-2x text-orange mb-2"></i>
            <h6 class="fw-bold mb-1">Exclusive Content</h6>
            <p class="small text-muted mb-0">
              Early access to new features and premium recipes.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main footer (dark) -->
  <section class="footer-main py-5">
    <div class="container-fluid px-4">
      <div class="container">
        <div class="row gy-4">
          <div class="col-lg-4">
            <h5 class="fw-bold text-white mb-2">Smart-Zaika</h5>
            <p class="small text-muted">
              AI-powered recipe discovery, planning and personalization.
            </p>
            <div class="mt-3">
              <a href="#" class="social-link me-2" aria-label="Instagram">
                <i class="fab fa-instagram"></i>
              </a>
              <a href="#" class="social-link me-2" aria-label="LinkedIn">
                <i class="fab fa-linkedin"></i>
              </a>
              <a href="#" class="social-link" aria-label="GitHub">
                <i class="fab fa-github"></i>
              </a>
            </div>
          </div>

          <div class="col-6 col-md-2">
            <h6 class="fw-bold text-white">Features</h6>
            <ul class="list-unstyled small text-muted">
              <li>AI Recipe Recommendations</li>
              <li>Meal Planning</li>
              <li>Nutritional Analysis</li>
              <li>Cooking Trends</li>
            </ul>
          </div>

          <div class="col-6 col-md-3">
            <h6 class="fw-bold text-white">Recipes</h6>
            <ul class="list-unstyled small text-muted">
              <li>Quick & Easy</li>
              <li>Healthy Options</li>
              <li>World Cuisine</li>
              <li>Vegetarian</li>
            </ul>
          </div>

          <div class="col-12 col-md-3">
            <h6 class="fw-bold text-white">Support</h6>
            <ul class="list-unstyled small text-muted">
              <li>
                <a href="/contact" class="text-muted text-decoration-none">Help Center</a>
              </li>
              <li>
                <a href="/privacy" class="text-muted text-decoration-none">Privacy Policy</a>
              </li>
              <li class="text-muted">Terms of Service</li>
              <li class="text-muted">API Documentation</li>
            </ul>
          </div>
        </div>

        <div class="row mt-4">
          <div class="col-12 text-center">
            <small class="text-muted">
              © <%= new Date().getFullYear() %> Smart-Zaika. All rights reserved.
            </small>
          </div>
        </div>
      </div>
    </div>
  </section>
</footer>

<!-- required scripts/styles -->
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
  crossorigin="anonymous"
/>
